<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 数据源配置 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="数据源配置"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchAutoRefresh"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="自动刷新基本面数据"
                    android:checked="true"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="自动刷新过期的基本面数据"
                    android:textSize="12sp"
                    android:alpha="0.6"
                    android:layout_marginStart="52dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="缓存有效期"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderCacheDays"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="1"
                    android:valueTo="7"
                    android:value="1"
                    android:stepSize="1"/>

                <TextView
                    android:id="@+id/tvCacheDays"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1天"
                    android:textSize="12sp"
                    android:alpha="0.6"
                    android:gravity="end"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 显示配置 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="显示配置"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchShowFinancial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="显示财务指标"
                    android:checked="true"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchShowGrowth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="显示成长性分析"
                    android:checked="true"
                    android:layout_marginTop="8dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchShowDividend"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="显示分红信息"
                    android:checked="true"
                    android:layout_marginTop="8dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchShowInstitution"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="显示机构持仓"
                    android:checked="true"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 分析配置 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="分析配置"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchIncludeFundamentalInAnalysis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="分析时包含基本面数据"
                    android:checked="true"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="在智能分析中自动包含基本面数据"
                    android:textSize="12sp"
                    android:alpha="0.6"
                    android:layout_marginStart="52dp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 缓存管理 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="缓存管理"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/tvCacheInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="缓存数据: 0 条"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnClearCache"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="清空缓存"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
