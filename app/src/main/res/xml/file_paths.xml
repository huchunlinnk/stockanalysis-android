<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 
        FileProvider 路径配置
        用于分享生成的报告图片
    -->
    
    <!-- 应用缓存目录 -->
    <cache-path
        name="cache"
        path="." />
    
    <!-- 应用文件目录 -->
    <files-path
        name="files"
        path="." />
    
    <!-- 外部存储的图片目录 -->
    <external-files-path
        name="pictures"
        path="Pictures/" />
    
    <!-- 外部存储的缓存目录 -->
    <external-cache-path
        name="external_cache"
        path="." />
    
    <!-- 外部存储根目录（Android 10 以下需要） -->
    <external-path
        name="external"
        path="." />
</paths>
